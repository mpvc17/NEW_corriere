{
  "$schema": "https://schemas.wp.org/wp/6.6/theme.json",
  "version": 3,
  "settings": {
    "appearanceTools": true,
    "color": {
      "palette": [
        { "slug": "brand",  "color": "#0f172a", "name": "Brand" },
        { "slug": "accent", "color": "#bc553a", "name": "Accent" },
        { "slug": "muted",  "color": "#6b7280", "name": "Muted" }
      ]
    },
    "spacing": {
      "units": ["px", "rem", "%"]
    },
    "typography": {
      "fontFamilies": [
        {
          "slug": "system",
          "fontFamily": "-apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, system-ui, sans-serif"
        }
      ],
      "fontSizes": [
        { "slug": "sm",   "size": "0.875rem" },
        { "slug": "base", "size": "1rem" },
        { "slug": "lg",   "size": "1.125rem" },
        { "slug": "xl",   "size": "1.375rem" },
        { "slug": "2xl",  "size": "1.75rem" }
      ]
    }
  },
  "styles": {
    "typography": { "fontFamily": "var(--wp--preset--font-family--system)" },
    "spacing": { "blockGap": "0.75rem" }
  }
}
